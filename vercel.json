{
  "env": {
    "TENNIS_SPORT_KEY": "tennis_atp_french_open",
    "TENNIS_SPORT_KEY_NOTES": "Roland Garros active May17-Jun7. Next: tennis_atp_wimbledon (Jun21-Jul12). Grass swing: tennis_atp_stuttgart (Jun6-14), tennis_atp_queens (Jun13-21). General ATP fallback: tennis_atp"
  },
  "rewrites": [
    { "source": "/", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 128,
      "maxDuration": 5
    },
    "api/webhook.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/tennis-picks.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/picks-log.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/calibration.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/odds.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/nba-picks.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/nba-resolve.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/nba-validation.js": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/nba-cron.js": {
      "memory": 128,
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
