# BetIntel WS Server + Ingest Worker — copy to .env

# Redis (required — same instance used by Vercel API)
REDIS_URL=redis://default:password@your-redis-host:6379

# Odds API
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# WebSocket server
WS_PORT=8080
WS_AUTH_SECRET=change-this-to-a-random-32-char-string
WS_ALLOWED_ORIGINS=https://betintel.vercel.app,http://localhost:3000
WS_MAX_CLIENTS=500

# Sports + markets
BETINTEL_ALLOWED_SPORTS=baseball_mlb,basketball_nba,basketball_wnba,americanfootball_nfl,icehockey_nhl
INGEST_MARKETS=h2h,spreads

# Ingest timing
INGEST_INTERVAL_MS=20000
ODDS_STALE_WINDOW_SECONDS=120
