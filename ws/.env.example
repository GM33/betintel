# BetIntel WS Server + Ingest Worker — environment variables
# Copy to .env for local development. Never commit .env.

# ── SHARED (both services) ──────────────────────────────────────────
# Redis connection string
# Local: redis://localhost:6379
# Railway: redis://default:<pw>@redis.railway.internal:6379
REDIS_URL=redis://localhost:6379

# HMAC secret — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WS_AUTH_SECRET=replace_with_64_char_hex_string

# ── WS SERVER ───────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── INGEST WORKER ───────────────────────────────────────────────────
# Get your key at https://the-odds-api.com (free tier = 500 req/mo)
ODDS_API_KEY=replace_with_your_odds_api_key

# How often to run ingest (ms). Default: 120000 (2 min)
# INGEST_INTERVAL_MS=120000

# Sports to ingest (comma-separated)
# INGEST_SPORTS=baseball_mlb,basketball_nba,soccer_fifa_world_cup
