{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/mlb/Dockerfile",
    "buildEnvironment": "V3"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "/bin/sh -c \"exec uvicorn mlb.api.main:app --host 0.0.0.0 --port $PORT\"",
    "sleepApplication": false,
    "useLegacyStacker": false,
    "ipv6EgressEnabled": true,
    "multiRegionConfig": {
      "sfo": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
